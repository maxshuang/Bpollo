{
  "name": "bpollo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "services/*",
    "packages/*",
    "apps/*",
    "tests"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "pnpm --filter @bpollo/tests run test:integration",
    "test:e2e": "pnpm --filter @bpollo/tests run test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
